---
// Gold Mini-App – Buy Digital Gold
const title = "Nexus Digital Gold";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title>{title}</title>
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://cdn-icons-png.flaticon.com https://images.unsplash.com; connect-src 'self' http://localhost:8080 http://10.0.2.2:8080 http://192.168.* ws:;" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif; }
    
    body {
      background: #090d16;
      color: #f8fafc;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: env(safe-area-inset-top, 1.5rem) 1rem env(safe-area-inset-bottom, 1.5rem) 1rem;
    }

    #mainContent {
      width: 100%;
      max-width: 380px;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    /* Premium Header Card */
    .header-card {
      background: linear-gradient(180deg, #131b2e 0%, #0d1324 100%);
      border: 1px solid #1e293b;
      border-radius: 20px;
      padding: 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .header-user {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .avatar {
      width: 40px;
      height: 40px;
      background: radial-gradient(circle, #fbbf24 0%, #d97706 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.2);
    }

    .user-info h2 {
      font-size: 0.95rem;
      font-weight: 700;
      color: #ffffff;
    }

    .user-info p {
      font-size: 0.75rem;
      color: #94a3b8;
    }

    /* Premium Live Price Card */
    .price-card {
      background: #111827;
      border: 1px solid #1f2937;
      border-radius: 24px;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }

    .price-card::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(251, 191, 36, 0.05) 0%, transparent 70%);
      pointer-events: none;
    }

    .price-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
    }

    .price-badge {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: #34d399;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 0.25rem 0.6rem;
      border-radius: 20px;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .pulse-dot {
      width: 6px;
      height: 6px;
      background: #10b981;
      border-radius: 50%;
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0% { transform: scale(0.9); opacity: 0.6; }
      50% { transform: scale(1.2); opacity: 1; }
      100% { transform: scale(0.9); opacity: 0.6; }
    }

    .gold-rate {
      font-size: 2.25rem;
      font-weight: 900;
      color: #f8fafc;
      letter-spacing: -1px;
    }

    .gold-rate span {
      color: #fbbf24;
    }

    /* Chart Canvas */
    .chart-container {
      width: 100%;
      height: 80px;
      margin-top: 1rem;
    }

    /* Calculator and Purchase Control */
    .buy-card {
      background: #111827;
      border: 1px solid #1f2937;
      border-radius: 24px;
      padding: 1.5rem;
    }

    .section-title {
      font-size: 0.8rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 1rem;
    }

    /* Value Selectors */
    .preset-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }

    .preset-btn {
      background: #1f2937;
      border: 1px solid #374151;
      color: #cbd5e1;
      font-size: 0.85rem;
      font-weight: 700;
      padding: 0.6rem 0;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .preset-btn.active {
      background: #fbbf24;
      border-color: #fbbf24;
      color: #090d16;
      box-shadow: 0 4px 12px rgba(251, 191, 36, 0.2);
    }

    /* Dynamic Input Fields */
    .input-wrapper {
      position: relative;
      margin-bottom: 1.25rem;
    }

    .currency-symbol {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      font-weight: 700;
      font-size: 1.1rem;
    }

    .gold-input {
      width: 100%;
      background: #090d16;
      border: 1px solid #374151;
      color: #ffffff;
      padding: 0.9rem 1rem 0.9rem 2.2rem;
      border-radius: 14px;
      font-size: 1.1rem;
      font-weight: 800;
      outline: none;
      transition: border-color 0.2s ease;
    }

    .gold-input:focus {
      border-color: #fbbf24;
    }

    /* Weight Readout */
    .readout-box {
      background: #1f2937;
      border-radius: 14px;
      padding: 0.9rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }

    .readout-label {
      font-size: 0.8rem;
      color: #94a3b8;
      font-weight: 500;
    }

    .readout-value {
      font-size: 1rem;
      color: #fbbf24;
      font-weight: 800;
    }

    /* Action Button */
    .buy-btn {
      width: 100%;
      padding: 1rem;
      border: none;
      border-radius: 14px;
      background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%);
      color: #090d16;
      font-size: 0.95rem;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.1s ease, opacity 0.2s ease;
      box-shadow: 0 4px 16px rgba(217, 119, 6, 0.25);
    }

    .buy-btn:active {
      transform: scale(0.98);
    }

    .buy-btn:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    /* Status Notifications */
    .status {
      margin-top: 1rem;
      padding: 0.9rem;
      border-radius: 12px;
      font-size: 0.8rem;
      line-height: 1.4;
      border: 1px solid transparent;
      display: none;
    }

    .status.success { display: block; background: rgba(16, 185, 129, 0.1); color: #34d399; border-color: rgba(16, 185, 129, 0.2); }
    .status.error { display: block; background: rgba(239, 68, 68, 0.1); color: #f87171; border-color: rgba(239, 68, 68, 0.2); }
    .status.info { display: block; background: rgba(148, 163, 184, 0.08); color: #cbd5e1; border-color: rgba(148, 163, 184, 0.15); }

    /* Unauthorized State Card */
    #unauthorizedState {
      background: rgba(239, 68, 68, 0.05);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 24px;
      padding: 2.25rem 1.5rem;
      text-align: center;
      max-width: 360px;
      display: none;
      box-shadow: 0 10px 25px rgba(239, 68, 68, 0.05);
    }

    .warning-icon {
      font-size: 3.5rem;
      margin-bottom: 1.25rem;
      animation: alert-pulse 2s infinite;
    }

    @keyframes alert-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }

    #unauthorizedState h2 {
      color: #f87171;
      font-size: 1.3rem;
      font-weight: 800;
      margin-bottom: 0.75rem;
    }

    #unauthorizedState p {
      color: #94a3b8;
      font-size: 0.85rem;
      line-height: 1.5;
      margin-bottom: 1.5rem;
    }

    #unauthorizedReason {
      font-size: 0.75rem;
      color: #f87171;
      font-family: monospace;
      background: rgba(0, 0, 0, 0.3);
      padding: 0.5rem;
      border-radius: 8px;
      border: 1px solid rgba(239, 68, 68, 0.1);
    }
  </style>
</head>
<body>
  <!-- Main Content Dashboard -->
  <div id="mainContent">
    <!-- Header Greeting -->
    <div class="header-card">
      <div class="header-user">
        <div class="avatar">🪙</div>
        <div class="user-info">
          <h2 id="welcomeUser">Sarthak</h2>
          <p id="authBadge">Initializing secure handshake...</p>
        </div>
      </div>
      <div class="price-badge">
        <div class="pulse-dot"></div>
        <span>LIVE PRICE</span>
      </div>
    </div>

    <!-- Live Gold Rate and Chart -->
    <div class="price-card">
      <div class="price-header">
        <span style="font-size: 0.75rem; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">XAU / USD (1g)</span>
        <span style="font-size: 0.8rem; color: #34d399; font-weight: 700;">+1.42% Today</span>
      </div>
      <div class="gold-rate">$<span id="rateValue">78.45</span></div>
      <div class="chart-container">
        <canvas id="goldChart" width="340" height="80"></canvas>
      </div>
    </div>

    <!-- Buying Panel -->
    <div class="buy-card">
      <h3 class="section-title">Buy Digital Gold</h3>
      
      <!-- Preset Buttons -->
      <div class="preset-grid">
        <button class="preset-btn active" data-val="10">$10</button>
        <button class="preset-btn" data-val="50">$50</button>
        <button class="preset-btn" data-val="100">$100</button>
        <button class="preset-btn" id="customPresetBtn">Custom</button>
      </div>

      <!-- Custom USD Input -->
      <div class="input-wrapper">
        <span class="currency-symbol">$</span>
        <input type="number" id="usdAmount" class="gold-input" value="10" min="1" step="0.5" />
      </div>

      <!-- Live Gold Weight Output -->
      <div class="readout-box">
        <span class="readout-label">Estimated Gold Weight</span>
        <span class="readout-value"><span id="weightValue">0.1275</span> g</span>
      </div>

      <!-- Buy Action Button -->
      <button id="buyBtn" class="buy-btn">Authorize Purchase</button>
      
      <!-- Live Status Message -->
      <div id="statusMessage" class="status"></div>
    </div>
  </div>

  <!-- Unauthorized Page State Overlay -->
  <div id="unauthorizedState">
    <div class="warning-icon">⚠️</div>
    <h2>Unauthorized Session</h2>
    <p>Your session token with the parent application is invalid, missing, or expired. Please relaunch this service from your secure dashboard.</p>
    <div id="unauthorizedReason">Reason: Bridge not loaded</div>
  </div>

  <script type="module">
    (() => {
      const buyBtn = document.getElementById('buyBtn');
      const welcomeUser = document.getElementById('welcomeUser');
      const authBadge = document.getElementById('authBadge');
      const statusMessage = document.getElementById('statusMessage');
      const usdAmountInput = document.getElementById('usdAmount');
      const weightValue = document.getElementById('weightValue');
      const presetButtons = document.querySelectorAll('.preset-btn');
      const customPresetBtn = document.getElementById('customPresetBtn');
      
      let jwtToken = '';
      let username = '';
      const GOLD_PRICE_PER_GRAM = 78.45;

      // Sparkline Canvas Logic
      const canvas = document.getElementById('goldChart');
      if (canvas) {
        const ctx = canvas.getContext('2d');
        const pricePoints = [77.10, 77.34, 76.90, 77.45, 77.80, 78.10, 77.92, 78.20, 78.45];
        
        ctx.strokeStyle = '#fbbf24';
        ctx.lineWidth = 2.5;
        
        const gradient = ctx.createLinearGradient(0, 0, 0, 80);
        gradient.addColorStop(0, 'rgba(251, 191, 36, 0.25)');
        gradient.addColorStop(1, 'rgba(251, 191, 36, 0.0)');
        
        const xStep = canvas.width / (pricePoints.length - 1);
        const yMin = 76.5;
        const yMax = 79.0;
        const yScale = canvas.height / (yMax - yMin);
        
        ctx.beginPath();
        pricePoints.forEach((price, idx) => {
          const x = idx * xStep;
          const y = canvas.height - ((price - yMin) * yScale);
          if (idx === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Fill under the line
        ctx.lineTo((pricePoints.length - 1) * xStep, canvas.height);
        ctx.lineTo(0, canvas.height);
        ctx.closePath();
        ctx.fillStyle = gradient;
        ctx.fill();
      }

      function updateWeight() {
        const usdVal = parseFloat(usdAmountInput.value) || 0;
        const computedWeight = usdVal / GOLD_PRICE_PER_GRAM;
        weightValue.textContent = computedWeight.toFixed(4);
      }

      // Initialize default weight calculation
      updateWeight();

      usdAmountInput.addEventListener('input', () => {
        // Deselect presets if custom typing
        let matchesPreset = false;
        presetButtons.forEach(btn => {
          if (btn.dataset.val === usdAmountInput.value) {
            btn.classList.add('active');
            matchesPreset = true;
          } else {
            btn.classList.remove('active');
          }
        });
        if (!matchesPreset) {
          customPresetBtn.classList.add('active');
        } else {
          customPresetBtn.classList.remove('active');
        }
        updateWeight();
      });

      // Preset click handler
      presetButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          if (btn.dataset.val) {
            presetButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            usdAmountInput.value = btn.dataset.val;
            updateWeight();
          }
        });
      });

      function showStatus(message, type = 'info') {
        statusMessage.textContent = message;
        statusMessage.className = `status ${type}`;
      }

      function clearStatus() {
        statusMessage.className = 'status';
        statusMessage.textContent = '';
      }

      function showUnauthorizedState(reason) {
        document.getElementById('mainContent').style.display = 'none';
        document.getElementById('unauthorizedState').style.display = 'block';
        document.getElementById('unauthorizedReason').textContent = `Reason: ${reason}`;
      }

      async function initializeSession() {
        const isFlutter = typeof window.flutter_inappwebview !== 'undefined' &&
                          typeof window.flutter_inappwebview.callHandler === 'function';

        if (!isFlutter) {
          // Simulation fallback for browser-based development
          jwtToken = 'mock-jwt-token-for-local-browser-dev';
          username = 'sarthak-dev';
          welcomeUser.textContent = username;
          authBadge.textContent = '⚠ Browser Simulation Session';
          authBadge.style.color = '#fbbf24';
          showStatus("Policy requires Native Container. Running in browser simulation.", "info");
          return;
        }

        try {
          // Call the host bridge handler to acquire the token
          const result = await window.flutter_inappwebview.callHandler('getAuthSession');
          const session = (typeof result === 'string') ? JSON.parse(result) : result;

          if (session && session.success && session.token) {
            jwtToken = session.token;
            username = session.username || 'sarthak';
            
            // Customize UI
            welcomeUser.textContent = username;
            authBadge.textContent = '✓ Secure Session Connected';
            authBadge.style.color = '#10b981';
            showStatus(`Session loaded successfully for ${username}.`, 'success');
          } else {
            showUnauthorizedState(session?.error || 'Missing Session Credentials');
          }
        } catch (err) {
          console.error("Handshake failed:", err);
          showUnauthorizedState('Bridge Connection Error: ' + err.message);
        }
      }

      // Lifecycle Mount check for InAppWebView Bridge
      if (typeof window.flutter_inappwebview !== 'undefined' &&
          typeof window.flutter_inappwebview.callHandler === 'function') {
        initializeSession();
      } else {
        window.addEventListener("flutterInAppWebViewPlatformReady", () => {
          initializeSession();
        });
      }

      buyBtn.addEventListener('click', async () => {
        const BUY_AMOUNT = parseFloat(usdAmountInput.value) || 0;
        if (BUY_AMOUNT <= 0) {
          showStatus("Please enter a valid purchase amount.", "error");
          return;
        }

        clearStatus();
        buyBtn.disabled = true;
        buyBtn.textContent = 'Authorizing...';

        const isFlutter = typeof window.flutter_inappwebview !== 'undefined' &&
                          typeof window.flutter_inappwebview.callHandler === 'function';

        try {
          const payload = {
            amount: BUY_AMOUNT,
            currency: "USD",
            miniAppId: "gold-app",
            description: `Buy ${weightValue.textContent}g of Digital Gold`,
            token: jwtToken
          };

          let result;
          if (isFlutter) {
            result = await window.flutter_inappwebview.callHandler('requestPayment', JSON.stringify(payload));
          } else {
            // Browser simulation delay
            await new Promise(resolve => setTimeout(resolve, 800));
            result = { success: true, txnId: 'TXN-SIM-' + Math.random().toString(36).substr(2, 9).toUpperCase() };
          }

          const response = (typeof result === 'string') ? JSON.parse(result) : result;

          if (response && response.success) {
            showStatus(`Purchase successful! Transaction ID: ${response.txnId || 'N/A'}. Exit to verify wallet.`, 'success');
            buyBtn.textContent = "Purchased ✓";
          } else {
            showStatus(`Purchase failed: ${response?.message || 'Transaction rejected'}`, 'error');
            buyBtn.disabled = false;
            buyBtn.textContent = "Authorize Purchase";
          }
        } catch (err) {
          console.error("JSBridge error:", err);
          showStatus("Communication error with Super App Container.", 'error');
          buyBtn.disabled = false;
          buyBtn.textContent = "Authorize Purchase";
        }
      });
    })();
  </script>
</body>
</html>
